{{ "collection.css" | asset_url | stylesheet_tag }}

<section class="collection">

  {% if section.settings.title != blank %}
    <h2 class="collection__title">{{ section.settings.title }}</h2>
  {% endif %}
  <section class="collection__grid">
    {% for product in section.settings.collection.products %}

      <div class="collection__product-card">
        <img
          src="{{product.featured_image |  image_url }}"
          alt="{{product.title}}"
          width="200"
          height="200">
        <h3>{{ product.title }}</h3>
        <p class="collection__price">{{ product.price | money }}</p>
        <a class="collection__card-button" href="{{product.url}}">Ver produto</a>
      </div>

    {% endfor %}

  </section>
</section>


{% schema %}
  {
    "name": "Collection",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label":"Título",
        "default": "Produtos Mais Vendidos"
      }, {
        "type": "collection",
        "id": "collection",
        "label": "Coleção de meias"
      }
    ]
  }
{% endschema %}